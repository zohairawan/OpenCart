<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Parallel Suite">
    <listeners>
        <listener class-name="com.opencart.listener.TestListener"/>
    </listeners>

    <test name="Parallel Test" parallel="classes" thread-count="3">
        <parameter name="browser" value="chrome"/>

        <packages>
            <package name="com.opencart.tests.login"/>
        </packages>
    </test>
</suite>