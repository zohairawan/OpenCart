<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Sanity Suite">
    <listeners>
        <listener class-name="com.opencart.listener.TestListener"/>
    </listeners>

    <test name="Sanity Test">
        <parameter name="browser" value="chrome"/>

        <groups>
            <run>
                <include name="sanity"/>
            </run>
        </groups>

        <packages>
            <package name="com.opencart.tests.login"/>
        </packages>
    </test>
</suite>