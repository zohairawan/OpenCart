<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Groups Suite">
    <groups>
        <run>
            <include name="sanity"/>
        </run>
    </groups>

    <listeners>
        <listener class-name="com.opencart.listener.TestListener"/>
    </listeners>

    <test name="Groups Test">
        <parameter name="browser" value="firefox"/>
        <packages>
            <package name="com.opencart.tests.login"/>
        </packages>
    </test>
</suite>