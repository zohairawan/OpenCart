<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Parallel Cross-Browser Suite" parallel="tests" thread-count="10">
    <listeners>
        <listener class-name="com.opencart.listener.TestListener"/>
    </listeners>

    <test name="Valid Login Test Firefox">
        <parameter name="browser" value="firefox"/>
        <parameter name="operatingSystem" value="windows"/>

        <classes>
            <class name="com.opencart.tests.login.TC_LF_001_LoginTest"/>
        </classes>
    </test>

    <test name="Invalid Login Test Firefox">
        <parameter name="browser" value="firefox"/>
        <parameter name="operatingSystem" value="windows"/>

        <classes>
            <class name="com.opencart.tests.login.TC_LF_002_LoginTest"/>
        </classes>
    </test>

    <test name="Email and Password Placeholder Test Firefox">
        <parameter name="browser" value="firefox"/>
        <parameter name="operatingSystem" value="windows"/>

        <classes>
            <class name="com.opencart.tests.login.TC_LF_008_LoginTest"/>
        </classes>
    </test>

    <test name="Invalid Login Data-Driven Test Firefox">
        <parameter name="browser" value="firefox"/>
        <parameter name="operatingSystem" value="windows"/>

        <classes>
            <class name="com.opencart.tests.login.InvalidLoginExcelDDTest"/>
        </classes>
    </test>

    <test name="Valid Login Test Chrome">
        <parameter name="browser" value="chrome"/>
        <parameter name="operatingSystem" value="windows"/>

        <classes>
            <class name="com.opencart.tests.login.TC_LF_001_LoginTest"/>
        </classes>
    </test>

    <test name="Invalid Login Test Chrome">
        <parameter name="browser" value="chrome"/>
        <parameter name="operatingSystem" value="windows"/>

        <classes>
            <class name="com.opencart.tests.login.TC_LF_002_LoginTest"/>
        </classes>
    </test>

    <test name="Email and Password Placeholder Test Chrome">
        <parameter name="browser" value="chrome"/>
        <parameter name="operatingSystem" value="windows"/>

        <classes>
            <class name="com.opencart.tests.login.TC_LF_008_LoginTest"/>
        </classes>
    </test>

    <test name="Invalid Login Data-Driven Test Chrome">
        <parameter name="browser" value="chrome"/>
        <parameter name="operatingSystem" value="windows"/>

        <classes>
            <class name="com.opencart.tests.login.InvalidLoginExcelDDTest"/>
        </classes>
    </test>
</suite>